# Google Gemini API key (required - get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# WebSocket server port (optional, default: 8080)
WS_PORT=8080

# Gemini model (optional, default: gemini-3.1-flash-lite)
# Free-tier models supporting audio+JSON (verified working):
#   gemini-3.1-flash-lite      v3.1, fast, audio+JSON works
#   gemini-2.5-flash            20 RPD (stable but low quota)
#   gemini-2.5-flash-lite      503 on audio (does not support audio on free tier)
# GEMINI_MODEL=gemini-3.1-flash-lite

# Gemini Live API model (optional, default: gemini-3.1-flash-live-preview)
# Used for real-time bidirectional audio streaming via Gemini Live API (BidiGenerateContent)
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
